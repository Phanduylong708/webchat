DATABASE_URL=postgresql://postgres:postgres@localhost:5432/webchat
PORT=3000
JWT_SECRET=change-me
JWT_EXPIRES_IN=1d

# Optional: required for avatar and chat media uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: backend can still run without Redis
REDIS_HOST=localhost
REDIS_PORT=6379
